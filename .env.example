# Copie este arquivo para .env e preencha os valores reais.
# O .env NUNCA deve ser commitado (manter no .gitignore).

# =============================================================
#  CONFIGURAÇÃO PRINCIPAL DO Q-MANAGER
#
#  Quando o IP dinâmico mudar:
#   1. Atualize PUBLIC_IP abaixo
#   2. Execute: ./scripts/update-ip.sh
# =============================================================

# ---------------------------------------------------------------
# Rede / acesso externo
# ---------------------------------------------------------------
# IP público atual (obtido via: curl -s ifconfig.me)
PUBLIC_IP=207.xxx.xx.xxx

# Portas expostas pelo nginx no host
HTTP_PORT=80
HTTPS_PORT=443

# ---------------------------------------------------------------
# GitHub (para pull de imagens do GHCR e CI/CD)
# ---------------------------------------------------------------
# Seu usuário ou organização no GitHub (letras minúsculas)
GITHUB_OWNER=usuariogithub

# ---------------------------------------------------------------
# Banco de dados PostgreSQL
# ---------------------------------------------------------------
POSTGRES_DB=fila_atendimento
POSTGRES_USER=postgres
POSTGRES_PASSWORD=SenhaSegura123

# ---------------------------------------------------------------
# E-mail (Gmail SMTP)
# ---------------------------------------------------------------
MAIL_USER=q.manager.systems@gmail.com
MAIL_PASSWORD=senhaSegura123

# ---------------------------------------------------------------
# CORS
# O nginx garante mesma origem em produção; '*' é seguro aqui.
# ---------------------------------------------------------------
CORS_ALLOWED_ORIGINS=*
